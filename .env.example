# === DATABASE CONFIGURATION ===
MONGO_URI=mongodb://mongodb:27017/
DB_NAME=youth_pulse_db

# === AI SERVICES ===
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# === FRONTEND CONFIGURATION ===
